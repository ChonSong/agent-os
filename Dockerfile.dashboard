# =============================================================================
# Dockerfile.dashboard — agent-os control plane + React dashboard
# Single-stage: builds frontend + backend, then runs everything.
# =============================================================================

FROM node:22-alpine

WORKDIR /app

# Install curl for healthcheck
RUN apk add --no-cache curl

# ── Build frontend ──────────────────────────────────────────────────────────
WORKDIR /app/frontend
COPY apps/dashboard/frontend/package.json apps/dashboard/frontend/package-lock.json* ./
RUN npm ci
COPY apps/dashboard/frontend/ ./
RUN npm run build

# ── Build backend ─────────────────────────────────────────────────────────
WORKDIR /app/backend
COPY apps/dashboard/backend/package.json apps/dashboard/backend/package-lock.json* ./
RUN npm ci
COPY apps/dashboard/backend/ ./
RUN npm run build

# ── Runtime ───────────────────────────────────────────────────────────────
WORKDIR /app

# Symlink frontend dist into backend's serving path
RUN ln -s /app/frontend/dist /app/frontend_dist

ENV NODE_ENV=production
ENV PORT=9120

EXPOSE 9120

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
  CMD curl -sf http://localhost:${PORT}/health || exit 1

CMD ["node", "backend/dist/index.js"]
