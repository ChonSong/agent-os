# =============================================================================
# Dockerfile.dashboard — agent-os control plane + React dashboard
# Single Alpine stage: builds frontend + backend, then runs.
# =============================================================================

FROM node:22-alpine

WORKDIR /app

# Install curl for healthcheck + docker-compose for deploy webhook
RUN apk add --no-cache curl && \
    curl -fsSL https://github.com/docker/compose/releases/download/v2.24.0/docker-compose-linux-x86_64 -o /usr/local/bin/docker-compose && \
    chmod +x /usr/local/bin/docker-compose

# ── Build frontend ───────────────────────────────────────────────────────────
WORKDIR /app/frontend
COPY apps/dashboard/frontend/package.json apps/dashboard/frontend/package-lock.json* ./
RUN npm ci
COPY apps/dashboard/frontend/ ./
RUN npm run build

# ── Build backend TypeScript ─────────────────────────────────────────────────
WORKDIR /app/backend
COPY apps/dashboard/backend/package.json apps/dashboard/backend/package-lock.json* ./
RUN npm ci
COPY apps/dashboard/backend/ ./
RUN npm run build

# ── Runtime ─────────────────────────────────────────────────────────────────
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=9120

EXPOSE 9120

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
  CMD curl -sf http://localhost:${PORT}/health || exit 1

CMD ["node", "backend/dist/index.js"]
