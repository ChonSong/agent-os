# =============================================================================
# Dockerfile.dashboard — Hermes Agent web dashboard for agent-os
# =============================================================================
# Uses the ChonSong/hermes-agent image which includes the api_proxies.py
# for nanobot agent-core and Docker Engine API routing.
#
# Image: ghcr.io/chonsong/hermes-agent (built from bf7269e)
# Build: https://github.com/ChonSong/hermes-agent/actions/workflows/agent-os.yml
#
# Usage:
#   docker compose up -d          # builds nanobot, pulls dashboard image
#   docker compose up --build     # force rebuild of nanobot
# =============================================================================

FROM ghcr.io/chonsong/hermes-agent:sha-bf7269eb0bfbc41d6045137b81020484163770f4

ENV NANOBOT_API_URL=http://nanobot:8900
ENV DOCKER_HOST_URL=http://localhost:2375
ENV HERMES_WEB_DIST=/opt/hermes/hermes_cli/web_dist

USER hermes

EXPOSE 9119

CMD ["python", "-m", "hermes_cli.main", "web", "--host", "0.0.0.0", "--port", "9119"]
