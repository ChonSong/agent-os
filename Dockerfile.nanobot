# =============================================================================
# Dockerfile.nanobot — nanobot agent-core as a container
# =============================================================================

FROM python:3.13-slim

ENV PYTHONUNBUFFERED=1
WORKDIR /app

# Copy nanobot source first (has pyproject.toml with [api] extras)
COPY packages/nanobot/ ./nanobot/

# Install uv, then nanobot with api extras
RUN pip install uv && \
    uv pip install --system -e ".[api]"

# nanobot reads config from ~/.nanobot/ (home=/opt/data/home)
RUN mkdir -p /opt/data/home/.nanobot

EXPOSE 8900

CMD ["python", "-m", "nanobot", "serve", "--host", "0.0.0.0", "--port", "8900"]
