FROM python:3.13-slim

ENV PYTHONUNBUFFERED=1
WORKDIR /app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:0.11.6-python3.13-trixie /uv /usr/local/bin/uv

# Copy only pyproject.toml first for caching
COPY packages/nanobot/pyproject.toml packages/nanobot/README.md packages/nanobot/LICENSE packages/nanobot/THIRD_PARTY_NOTICES.md ./

# Install nanobot with api extras
RUN uv pip install --system -e ".[api]"

# Copy source
COPY packages/nanobot/ ./nanobot/

# Runtime config directory
RUN mkdir -p /opt/data/home/.nanobot

# Default port for nanobot serve
EXPOSE 8900

CMD ["python", "-m", "nanobot", "serve", "--host", "0.0.0.0", "--port", "8900"]
