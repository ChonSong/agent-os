# =============================================================================
# Dockerfile.nanobot — nanobot agent-core as a container
# =============================================================================
# Multi-stage build: pulls uv from ghcr.io in the first stage,
# then copies the uv binary into the final image.
# =============================================================================

# ── Stage 1: Extract uv binary ───────────────────────────────────────────────
FROM ghcr.io/astral-sh/uv:0.11.6-python3.13-trixie AS uv

# ── Stage 2: nanobot runtime ──────────────────────────────────────────────────
FROM python:3.13-slim

ENV PYTHONUNBUFFERED=1
WORKDIR /app

# Copy uv binary from the uv stage
COPY --from=uv /uv /usr/local/bin/uv
COPY --from=uv /uvx /usr/local/bin/uvx

# Copy only pyproject.toml first for layer-cached dependency install
COPY packages/nanobot/pyproject.toml packages/nanobot/README.md packages/nanobot/LICENSE packages/nanobot/THIRD_PARTY_NOTICES.md ./

# Install nanobot with api extras
RUN uv pip install --system -e ".[api]"

# Copy nanobot source
COPY packages/nanobot/ ./nanobot/

# nanobot reads config from ~/.nanobot/ (home=/opt/data/home)
RUN mkdir -p /opt/data/home/.nanobot

EXPOSE 8900

CMD ["python", "-m", "nanobot", "serve", "--host", "0.0.0.0", "--port", "8900"]
